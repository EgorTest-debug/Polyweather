# Polymarket CLOB credentials (needed only for --live mode)
# Get private key: https://reveal.magic.link/polymarket
# Get wallet address: Polymarket Settings > Wallet Address

POLY_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLY_FUNDER=0xYOUR_WALLET_ADDRESS_HERE

# Signature type:
#   1 = email/Magic login (recommended)
#   0 = MetaMask/EOA
#   2 = smart contract proxy
POLY_SIGNATURE_TYPE=1
